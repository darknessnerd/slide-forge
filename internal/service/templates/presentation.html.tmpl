<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Presentation</title>

  <!-- PureCSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/purecss@3.0.0/build/pure-min.css"
        crossorigin="anonymous">

  <!-- Theme tokens -->
  <style>{{ .ThemeCSS }}</style>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      overflow: hidden;
    }

    /* ── Layout ─────────────────────────────────────────── */
    #app {
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    #slides-viewport {
      flex: 1;
      position: relative;
      overflow: hidden;
    }

    /* ── Slide ───────────────────────────────────────────── */
    .slide {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 4rem 6rem;
      background: var(--surface);
      box-shadow: var(--slide-shadow);
      will-change: opacity, transform;
    }

    /* ── Transitions ────────────────────────────────────── */
    /* Classes injected dynamically by Alpine — NOT attribute selectors */
    .t-enter        { transition: opacity 280ms ease; }
    .t-enter-start  { opacity: 0; }
    .t-enter-end    { opacity: 1; }
    .t-leave        { transition: opacity 200ms ease; }
    .t-leave-start  { opacity: 1; }
    .t-leave-end    { opacity: 0; }

    .ts-enter        { transition: transform 300ms cubic-bezier(.4,0,.2,1), opacity 300ms ease; }
    .ts-enter-start  { transform: translateX(60px); opacity: 0; }
    .ts-enter-end    { transform: translateX(0);    opacity: 1; }
    .ts-leave        { transition: transform 220ms ease, opacity 220ms ease; }
    .ts-leave-start  { transform: translateX(0);    opacity: 1; }
    .ts-leave-end    { transform: translateX(-60px);opacity: 0; }

    /* ── Title slide ────────────────────────────────────── */
    .slide[data-type="title"] {
      text-align: center;
      background: linear-gradient(135deg, var(--surface) 0%, var(--bg) 100%);
    }

    .slide[data-type="title"] .slide-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }

    /* ── Section slide ──────────────────────────────────── */
    .slide[data-type="section"] {
      background: var(--accent);
      color: #fff;
    }

    .slide[data-type="section"] .slide-title {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 600;
      color: #fff;
    }

    /* ── Summary slide ──────────────────────────────────── */
    .slide[data-type="summary"] .slide-title {
      color: var(--accent);
    }

    /* ── Content area ───────────────────────────────────── */
    .slide-title {
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-weight: 600;
      margin-bottom: 1.25rem;
      color: var(--text);
      align-self: flex-start;
      width: 100%;
    }

    .slide-content {
      width: 100%;
      max-width: 900px;
      font-size: clamp(1rem, 1.8vw, 1.2rem);
    }

    .slide-content p   { margin-bottom: 0.75rem; }
    .slide-content ul,
    .slide-content ol  { padding-left: 1.5rem; margin-bottom: 0.75rem; }
    .slide-content li  { margin-bottom: 0.35rem; }

    .slide-content code {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.1em 0.4em;
      font-size: 0.9em;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    }

    .slide-content pre {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
      margin-bottom: 0.75rem;
    }

    .slide-content pre code {
      background: none;
      border: none;
      padding: 0;
      font-size: 0.9em;
    }

    .slide-content table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 0.75rem;
      font-size: 0.95em;
    }

    .slide-content th,
    .slide-content td {
      border: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }

    .slide-content th {
      background: var(--code-bg);
      font-weight: 600;
    }

    .slide-content blockquote {
      border-left: 4px solid var(--accent);
      padding-left: 1rem;
      color: var(--subtext);
      margin-bottom: 0.75rem;
    }

    /* ── Progress bar ───────────────────────────────────── */
    #progress-bar-wrap {
      height: 4px;
      background: var(--progress-bg);
    }

    #progress-bar {
      height: 100%;
      background: var(--progress-fill);
      transition: width 280ms ease;
    }

    /* ── Navigation ─────────────────────────────────────── */
    #nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 0.75rem 1.5rem;
      background: var(--nav-bg);
      border-top: 1px solid var(--border);
      backdrop-filter: blur(8px);
    }

    #nav button {
      min-width: 80px;
      padding: 0.4rem 1.1rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 0.9rem;
      cursor: pointer;
      transition: background 150ms, color 150ms, border-color 150ms;
    }

    #nav button:not(:disabled):hover {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    #nav button:disabled {
      opacity: 0.35;
      cursor: default;
    }

    #slide-counter {
      font-size: 0.85rem;
      color: var(--subtext);
      min-width: 70px;
      text-align: center;
    }

    #fullscreen-btn {
      margin-left: auto;
    }

    /* ── Speaker notes ──────────────────────────────────── */
    #notes-panel {
      padding: 0.75rem 2rem;
      background: var(--notes-bg);
      border-top: 3px solid var(--notes-border);
      font-size: 0.85rem;
      color: var(--subtext);
      max-height: 120px;
      overflow-y: auto;
    }

    #notes-panel strong {
      color: var(--text);
    }

    /* ── Slide-number badge ─────────────────────────────── */
    #slide-badge {
      position: absolute;
      bottom: 0.6rem;
      right: 1rem;
      font-size: 0.7rem;
      color: var(--subtext);
      opacity: 0.5;
    }

    /* ── Thumbnail strip (hidden unless toggled) ────────── */
    #thumb-strip {
      display: flex;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      overflow-x: auto;
      background: var(--bg);
      border-top: 1px solid var(--border);
    }

    .thumb {
      flex-shrink: 0;
      width: 100px;
      height: 65px;
      border: 2px solid var(--border);
      border-radius: 4px;
      cursor: pointer;
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      text-align: center;
      padding: 4px;
      overflow: hidden;
      transition: border-color 120ms;
    }

    .thumb.active {
      border-color: var(--accent);
    }

    /* ── Mobile tweaks ──────────────────────────────────── */
    @media (max-width: 600px) {
      .slide { padding: 2rem 1.5rem; }
      #nav button { min-width: 60px; padding: 0.35rem 0.7rem; font-size: 0.8rem; }
    }
  </style>
</head>

<body>
<div id="app"
     x-data="presentation()"
     x-init="init()"
     @keydown.window="handleKey($event)">

  <!-- Progress bar -->
  {{ if .IncludeProgressBar }}
  <div id="progress-bar-wrap">
    <div id="progress-bar" :style="`width:${progress}%`"></div>
  </div>
  {{ end }}

  <!-- Slides viewport -->
  <div id="slides-viewport">
    <template x-for="(slide, index) in slides" :key="index">
      {{ if eq (print .TransitionStyle) "fade" }}
      <section class="slide"
               :data-type="slide.type"
               x-show="current === index"
               x-transition:enter="t-enter"
               x-transition:enter-start="t-enter-start"
               x-transition:enter-end="t-enter-end"
               x-transition:leave="t-leave"
               x-transition:leave-start="t-leave-start"
               x-transition:leave-end="t-leave-end">
      {{ else if eq (print .TransitionStyle) "slide" }}
      <section class="slide"
               :data-type="slide.type"
               x-show="current === index"
               x-transition:enter="ts-enter"
               x-transition:enter-start="ts-enter-start"
               x-transition:enter-end="ts-enter-end"
               x-transition:leave="ts-leave"
               x-transition:leave-start="ts-leave-start"
               x-transition:leave-end="ts-leave-end">
      {{ else }}
      <section class="slide"
               :data-type="slide.type"
               x-show="current === index">
      {{ end }}
        <h1 class="slide-title" x-text="slide.title" x-show="slide.title"></h1>
        <div class="slide-content" x-html="slide.content"></div>
        <span id="slide-badge" x-text="`${index + 1} / ${slides.length}`"></span>
      </section>
    </template>
  </div>

  <!-- Speaker notes -->
  {{ if .IncludeSpeakerNotes }}
  <div id="notes-panel" x-show="slides[current] && slides[current].notes">
    <strong>Notes:</strong>
    <span x-text="slides[current] ? slides[current].notes : ''"></span>
  </div>
  {{ end }}

  <!-- Navigation -->
  <div id="nav">
    <button @click="prev()" :disabled="current === 0">&#8592; Prev</button>
    <span id="slide-counter" x-text="`${current + 1} / ${slides.length}`"></span>
    <button @click="next()" :disabled="current === slides.length - 1">Next &#8594;</button>
    <button id="fullscreen-btn" @click="toggleFullscreen()" title="Fullscreen">&#9974;</button>
    <button @click="showThumbs = !showThumbs" title="Thumbnails">&#9783;</button>
  </div>

  <!-- Thumbnail strip -->
  <div id="thumb-strip" x-show="showThumbs">
    <template x-for="(slide, index) in slides" :key="index">
      <div class="thumb"
           :class="{ active: current === index }"
           @click="goto(index)"
           x-text="(index + 1) + '. ' + (slide.title || '…')">
      </div>
    </template>
  </div>

</div><!-- #app -->

<!-- Alpine.js -->
<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

<script>
  function presentation() {
    return {
      current: 0,
      showThumbs: false,
      slides: {{ .SlidesJSON }},

      get progress() {
        if (this.slides.length <= 1) return 100;
        return Math.round((this.current / (this.slides.length - 1)) * 100);
      },

      init() {
        // nothing to do — Alpine handles reactivity
      },

      next() {
        if (this.current < this.slides.length - 1) this.current++;
      },

      prev() {
        if (this.current > 0) this.current--;
      },

      goto(index) {
        if (index >= 0 && index < this.slides.length) this.current = index;
      },

      handleKey(e) {
        {{ if .EnableKeyboardNavigation }}
        if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); this.next(); }
        if (e.key === 'ArrowLeft')                   { e.preventDefault(); this.prev(); }
        if (e.key === 'Home')                        { e.preventDefault(); this.goto(0); }
        if (e.key === 'End')                         { e.preventDefault(); this.goto(this.slides.length - 1); }
        if (e.key === 'f' || e.key === 'F')          { this.toggleFullscreen(); }
        if (e.key === 't' || e.key === 'T')          { this.showThumbs = !this.showThumbs; }
        {{ end }}
      },

      toggleFullscreen() {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen().catch(() => {});
        } else {
          document.exitFullscreen().catch(() => {});
        }
      },
    };
  }
</script>
</body>
</html>
